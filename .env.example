# ---------------------------------------------------------------------------
# MealMesh environment variables
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Supabase — CLIENT-SAFE public values.
# The `EXPO_PUBLIC_` prefix exposes these to the app bundle (this is expected;
# Row Level Security, not secrecy, protects the data).
# Find them in: Supabase Dashboard → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Food photos (optional) — Pexels API key (free at pexels.com/api). When set,
# recipe cards show real photos; otherwise they show emoji tiles.
# EXPO_PUBLIC_PEXELS_KEY=

# Analytics (added later) — Mixpanel project token (client-safe).
# EXPO_PUBLIC_MIXPANEL_TOKEN=

# Web subscriptions — Freemius PUBLIC identifiers (client-safe).
# Find in the Freemius dashboard: Product → Settings.
# EXPO_PUBLIC_FREEMIUS_PRODUCT_ID=      # Product ID
# EXPO_PUBLIC_FREEMIUS_PLAN_ID=         # the Pro plan's ID
# EXPO_PUBLIC_FREEMIUS_PUBLIC_KEY=      # Keys → Public Key (pk_...)

# ---------------------------------------------------------------------------
# SERVER-ONLY SECRETS — do NOT put these here or anywhere in the app/repo.
# Set them in the Supabase Edge Function secrets instead:
#   Dashboard → Edge Functions → Secrets  (or `supabase secrets set ...`)
#
#   ANTHROPIC_API_KEY         ← your Claude API key (NEVER ships to the client)
#   FREEMIUS_SECRET_KEY       ← Freemius Keys → Secret Key (sk_...), for the webhook
#   SUPABASE_SERVICE_ROLE_KEY ← injected into functions automatically
# ---------------------------------------------------------------------------
