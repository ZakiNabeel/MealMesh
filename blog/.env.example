# URL of the main MealMesh app (where "Build your plan" CTAs link to).
# Leave unset to default to https://getmealmesh.com
PUBLIC_APP_URL=https://getmealmesh.com

# Pexels API key, used at build time only to fetch a real hero photo per
# article (matched against each article's `imageQuery` frontmatter field).
# Never sent to the client. Leave unset to fall back to the local placeholder
# SVG in public/images/articles/ for every article. Get a free key at
# https://www.pexels.com/api/
PEXELS_KEY=
