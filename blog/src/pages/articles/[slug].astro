---
import { getCollection, getEntry, render } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { APP_URL } from '../../lib/site';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, excerpt, heroImage, heroImageAlt, author, publishedAt, readingTime, metaTitle, metaDescription, relatedSlugs } =
  article.data;

const related = (
  await Promise.all(relatedSlugs.map((slug: string) => getEntry('articles', slug)))
).filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const dateLabel = publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  image: new URL(heroImage, Astro.site).toString(),
  author: { '@type': 'Organization', name: author },
  datePublished: publishedAt.toISOString(),
};
---

<BaseLayout title={metaTitle} description={metaDescription} image={heroImage} jsonLd={jsonLd}>
  <article class="wrap article">
    <p class="category">{article.data.category}</p>
    <h1>{title}</h1>
    <p class="meta">{author} · {dateLabel} · {readingTime}</p>
    <img src={heroImage} alt={heroImageAlt} class="hero" />

    <div class="body">
      <Content />
    </div>

    <a href={`${APP_URL}/onboarding`} class="cta">Build your household's plan →</a>

    {
      related.length > 0 && (
        <section class="related">
          <h2>Related reads</h2>
          <div class="related-grid">
            {related.map((entry) => (
              <ArticleCard article={entry} compact />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .article {
    padding-top: 48px;
    padding-bottom: 72px;
    max-width: 760px;
  }
  .category {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    font-size: clamp(28px, 4.2vw, 40px);
    margin-top: 10px;
  }
  .meta {
    color: var(--text-secondary);
    font-size: 14px;
    margin-top: 12px;
  }
  .hero {
    width: 100%;
    border-radius: 18px;
    margin-top: 28px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .body {
    margin-top: 32px;
    font-size: 16.5px;
    line-height: 1.75;
    color: var(--text);
  }
  .body :global(h2) {
    font-size: 23px;
    margin-top: 36px;
    margin-bottom: 14px;
  }
  .body :global(p) {
    margin-bottom: 18px;
  }
  .body :global(ul) {
    margin-bottom: 18px;
    padding-left: 22px;
  }
  .body :global(li) {
    margin-bottom: 8px;
  }
  .body :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }
  .cta {
    display: inline-block;
    margin-top: 12px;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    padding: 14px 26px;
    border-radius: 999px;
    transition: opacity 0.15s ease;
  }
  .cta:hover {
    opacity: 0.88;
  }
  .related {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .related h2 {
    font-size: 20px;
    margin-bottom: 18px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  @media (max-width: 560px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
