---
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getArticlesWithImages } from '../lib/articles';

const resolved = await getArticlesWithImages();
const latest = resolved.slice(0, 8);
// Tripled so the auto-drift carousel below can loop seamlessly — the visible
// window only ever looks into the middle copy, so the wraparound never shows.
const tripledLatest = [...latest, ...latest, ...latest];

const categories = ['All', 'Guides', 'Nutrition', 'Budget', 'Cultural'] as const;
---

<BaseLayout
  title="MealMesh Kitchen Notes — guides for households with mixed diets"
  description="Practical guides on planning meals for households where members follow different diets — halal, gluten-free, vegetarian, allergies, and budgets, all at one table."
>
  <section class="hero wrap">
    <h1>Kitchen notes</h1>
    <p class="lead">Practical guides for cooking one week that actually works for everyone at your table.</p>
  </section>

  <section class="carousel-wrap">
    <p class="wrap carousel-label">Latest</p>
    <div class="carousel-clip" id="carousel-clip" aria-label="Latest articles">
      <div class="carousel-track" id="carousel-track">
        {
          tripledLatest.map(({ article, image }, i) => (
            <div class="carousel-item" data-idx={i}>
              <ArticleCard article={article} image={image} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="wrap filters" role="tablist" aria-label="Filter by category">
    {
      categories.map((c) => (
        <button class="filter-btn" data-category={c} role="tab" aria-selected={c === 'All'}>
          {c}
        </button>
      ))
    }
  </section>

  <section class="wrap grid" id="grid">
    {
      resolved.map(({ article, image }) => (
        <div class="grid-item" data-category={article.data.category}>
          <ArticleCard article={article} image={image} />
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 56px;
    padding-bottom: 24px;
  }
  .hero h1 {
    font-size: clamp(34px, 5vw, 48px);
  }
  .lead {
    color: var(--text-secondary);
    font-size: 17px;
    margin-top: 10px;
    max-width: 520px;
  }
  .carousel-wrap {
    position: relative;
    padding-bottom: 36px;
  }
  .carousel-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .carousel-clip {
    overflow: hidden;
    width: 100%;
  }
  .carousel-clip.is-reduced-motion {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .carousel-track {
    display: flex;
    gap: 20px;
    padding: 4px max(24px, calc((100vw - 1080px) / 2)) 12px;
    will-change: transform;
  }
  .carousel-item {
    flex: 0 0 300px;
    transition: transform 0.26s ease, opacity 0.26s ease, filter 0.26s ease;
  }
  .carousel-track.any-hovered .carousel-item:not(.is-hovered) {
    opacity: 0.55;
    filter: blur(1.5px);
    transform: scale(0.97);
  }
  .carousel-item.is-hovered {
    transform: scale(1.06);
    z-index: 2;
  }
  .filters {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    padding-bottom: 28px;
  }
  .filter-btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--text-secondary);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 9px 18px;
    cursor: pointer;
  }
  .filter-btn[aria-selected='true'] {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-bottom: 64px;
  }
  @media (max-width: 860px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Slow, smooth auto-drift carousel. Hovering a card pauses the drift, pops
  // that card, and dims/blurs its neighbors. Tripled server-side so the loop
  // wraps invisibly; respects prefers-reduced-motion by falling back to a
  // plain manually-scrollable row instead of animating.
  const clip = document.getElementById('carousel-clip');
  const track = document.getElementById('carousel-track');

  if (clip && track) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      clip.classList.add('is-reduced-motion');
    } else {
      const items = Array.from(track.querySelectorAll<HTMLElement>('.carousel-item'));
      const PX_PER_SEC = 20;
      const setWidth = track.scrollWidth / 3;
      let x = -setWidth;
      let running = true;
      let last = performance.now();

      const tick = (now: number) => {
        const dt = (now - last) / 1000;
        last = now;
        if (running && setWidth > 0) {
          // Increasing x slides the track right, so cards drift left-to-right.
          x += PX_PER_SEC * dt;
          if (x >= 0) x -= setWidth;
          track.style.transform = `translateX(${x}px)`;
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      items.forEach((item) => {
        item.addEventListener('mouseenter', () => {
          running = false;
          track.classList.add('any-hovered');
          items.forEach((it) => it.classList.remove('is-hovered'));
          item.classList.add('is-hovered');
        });
        item.addEventListener('mouseleave', () => {
          running = true;
          track.classList.remove('any-hovered');
          item.classList.remove('is-hovered');
        });
      });
    }
  }

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.grid-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');
      const category = btn.dataset.category;
      items.forEach((item) => {
        const show = category === 'All' || item.dataset.category === category;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>
